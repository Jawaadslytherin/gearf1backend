# Copy this file to .env and fill in your values
PORT=3001
MONGODB_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/gearupf1?retryWrites=true&w=majority

# Admin auth (required for protected routes)
JWT_SECRET=your-secret-key-min-32-chars-for-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Optional: live football scores (free key at https://www.football-data.org/)
# FOOTBALL_DATA_API_KEY=your_api_key
